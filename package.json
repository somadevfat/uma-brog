{
  "name": "basic",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "bun run check && vite build --mode client && vite build",
    "check": "tsc --noEmit && biome check .",
    "lint": "biome check .",
    "lint:fix": "biome check . --write",
    "fmt": "biome format . --write",
    "test": "vitest run",
    "preview": "wrangler dev",
    "deploy": "bun run build && wrangler deploy"
  },
  "private": true,
  "dependencies": {
    "@hono/zod-validator": "^0.7.6",
    "@mdx-js/react": "^3.1.1",
    "@mdx-js/rollup": "^3.1.1",
    "better-auth": "^1.4.18",
    "drizzle-orm": "^0.45.1",
    "drizzle-zod": "^0.8.3",
    "hono": "^4.12.0",
    "honox": "0.1.54",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "@cloudflare/workers-types": "^4.20260227.0",
    "@hono/vite-build": "^1.3.0",
    "@hono/vite-dev-server": "^0.25.0",
    "@types/mdx": "^2.0.13",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "drizzle-kit": "^0.31.9",
    "vite": "^6.3.5",
    "vitest": "^4.0.18",
    "wrangler": "^4.4.0"
  }
}
